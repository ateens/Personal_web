GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# PostgreSQL persistence. Required for app state and private integration data.
DATABASE_URL=postgresql://user:password@localhost:5432/sygma_personal_web

# Optional. Defaults to "default"; use this to separate multiple app profiles in one DB.
APP_STATE_ID=default

# Optional legacy migration source. If present, this token is imported into PostgreSQL and removed.
GOOGLE_TOKEN_FILE=.data/google-token.json

# Optional for local development. Production Railway uses the pinned callback below.
# GOOGLE_REDIRECT_URI=http://127.0.0.1:4180/api/google/oauth/callback
# Production: GOOGLE_REDIRECT_URI=https://personalweb-production-81a6.up.railway.app/api/google/oauth/callback

# Optional for local development. Production Railway uses its own origin directly.
# PUBLIC_BASE_URL=https://personalweb-production-81a6.up.railway.app

# Optional for local non-production use. Every Railway runtime and every
# NODE_ENV=production process requires the access-code gate. The pinned
# production target gets its verifier from server/deployment-security.js;
# Railway previews must provide APP_ACCESS_PASSWORD_SHA256.
REQUIRE_APP_ACCESS_AUTH=0
# APP_ACCESS_PASSWORD_SHA256=sha256:<64 lowercase hexadecimal characters>
APP_SESSION_TTL_SECONDS=2592000

# Require If-Match/baseRevision on non-bootstrap /api/state writes.
# Keep disabled only while legacy clients still perform unconditional writes.
REQUIRE_STATE_PRECONDITION=0

# Fixed-window, per-process API limits. A value of 0 disables that route class.
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_STATE_READ_MAX=240
API_RATE_LIMIT_STATE_WRITE_MAX=120
API_RATE_LIMIT_GOOGLE_MUTATION_MAX=20
API_RATE_LIMIT_MAX_KEYS=10000

# State-write admission control. These limits are per Node process.
STATE_WRITE_MAX_CONCURRENCY=2
STATE_WRITE_MAX_QUEUE=16
STATE_WRITE_QUEUE_TIMEOUT_MS=10000

# The pinned Railway production target trusts Railway's X-Real-IP header
# automatically. Elsewhere, enable only behind an ingress that strips and
# recreates forwarded client-IP headers. The safe default is off.
TRUST_PROXY_IP_HEADERS=0
